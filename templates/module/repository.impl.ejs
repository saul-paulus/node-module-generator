export default class Prisma<%= className %>Repository {
  constructor({ prisma }) {
    this.prisma = prisma;
  }

  async findById(id) {
    return this.prisma.<%= camelName %>s.findUnique({
      where: { id },
    });
  }

  async create(data) {
    return this.prisma.<%= camelName %>s.create({ data });
  }
}
